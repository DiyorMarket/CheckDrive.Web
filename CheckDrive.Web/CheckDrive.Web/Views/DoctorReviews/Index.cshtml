@model IEnumerable<CheckDrive.Web.Models.DoctorReview>

@{
    ViewData["Title"] = "Doctor Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@ViewData["Title"]</h2>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Is Healthy</th>
            <th>Comments</th>
            <th>Date</th>
            <th>Driver ID</th>
            <th>Doctor ID</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var review in Model)
        {
            <tr>
                <td>@review.Id</td>
                <td>@review.IsHealthy</td>
                <td>@review.Comments</td>
                <td>@review.Date.ToShortDateString()</td>
                <td>@review.DriverId</td>
                <td>@review.DoctorId</td>
            </tr>
        }
    </tbody>
</table>
