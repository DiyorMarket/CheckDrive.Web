@model CheckDrive.Web.Models.DoctorReview
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Doctor Reviews</h2>

<div class="row">
    <div class="col-12">
        <ejs-grid id="doctorreviews-list" dataSource="@ViewBag.DoctorReviews" gridLines="Vertical" allowSorting="true">
            <e-grid-columns>
                <e-grid-column headerText="Id" field="Id" typeof="number"></e-grid-column>
                <e-grid-column headerText="Is Healthy" field="IsHealthy" typeof="text"></e-grid-column>
                <e-grid-column headerText="Comments" field="Comments" typeof="text"></e-grid-column>
                <e-grid-column headerText="Date" field="Date" typeof="text"></e-grid-column>
                <e-grid-column headerText="Driver Id" field="DriverId" typeof="text"></e-grid-column>
                <e-grid-column headerText="Doctor Id" field="DriverName" typeof="text"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>
</div>